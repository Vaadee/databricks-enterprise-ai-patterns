# Copy to .env for local development — never commit .env

# Lakebase Autoscaling
LAKEBASE_PROJECT_ID=long-running-inference
LAKEBASE_BRANCH_ID=production
LAKEBASE_DB_NAME=databricks_postgres

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<key>
AZURE_DEPLOYMENT_NAME=<deployment-name>
AZURE_API_VERSION=2024-02-01

# Databricks (auto-injected in Apps/serverless — only needed for local dev)
DATABRICKS_HOST=https://<workspace>.azuredatabricks.net
DATABRICKS_TOKEN=<pat>

# Worker job ID (resolved by DAB at deploy — set manually for local dev/testing)
WORKER_JOB_ID=<job-id>

# Tuning
FLUSH_EVERY=1000
TOKEN_REFRESH_SECS=3000
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10
